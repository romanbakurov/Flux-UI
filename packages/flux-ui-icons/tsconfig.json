{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "isolatedModules": true,

    "noEmit": true,

    "types": ["node"]
  },

  "include": ["scripts/**/*.ts", "src/**/*.ts", "src/**/*.tsx"],

  "exclude": ["node_modules", "dist"]
}
